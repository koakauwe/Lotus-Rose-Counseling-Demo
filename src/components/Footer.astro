      </div>
    </div>

    <!-- Bottom -->
    <div class="footer-bottom">
      <p>
        <a href="/privacy-policy/">Privacy Policy</a>
        <span class="dot">·</span>
        <a href="/terms/">Terms of Service</a>
      </p>
      <p class="copyright">&copy; {currentYear} Lotus Rose Counseling. All rights reserved.</p>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--blush-pink);
    color: var(--text-dark);
    padding: 60px 0 32px;
    font-size: 15px;
  }
  .footer-gradient-line {
    height: 3px;
    background: var(--dusty-mauve);
    margin-bottom: 0;
  }
  .footer-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 48px;
    margin-bottom: 48px;
  }
  .footer-heading {
    font-family: var(--font-heading);
    font-size: 22px;
    font-weight: 700;
    color: var(--text-dark);
    margin-bottom: 20px;
  }
  .footer-col ul {
    list-style: none;
  }
  .footer-col li {
    margin-bottom: 10px;
  }
  .footer-col a {
    color: var(--text-dark);
    opacity: 0.8;
    transition: all 0.2s;
  }
  .footer-col a:hover {
    color: var(--text-dark);
    opacity: 1;
    padding-left: 4px;
  }

  .contact-list li {
    display: flex;
    align-items: flex-start;
    gap: 10px;
  }
  .contact-list svg {
    flex-shrink: 0;
    margin-top: 3px;
    stroke: var(--text-dark);
  }
  .service-area {
    margin-top: 16px;
    font-size: 13px;
    color: var(--text-medium);
    line-height: 1.6;
  }

  .social-links {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .social-links a {
    display: flex;
    align-items: center;
    gap: 10px;
    color: var(--text-dark);
    opacity: 0.8;
  }
  .social-links a:hover { opacity: 1; }
  .social-links svg { stroke: var(--text-dark); }

  .footer-bottom {
    border-top: 1px solid rgba(61, 51, 48, 0.12);
    padding-top: 24px;
    text-align: center;
  }
  .footer-bottom p { color: var(--text-medium); font-size: 13px; margin-bottom: 8px; }
  .footer-bottom a { color: var(--text-dark); opacity: 0.6; }
  .footer-bottom a:hover { opacity: 1; }
  .dot { margin: 0 8px; opacity: 0.3; }
  .copyright { margin-bottom: 0; }

  @media (max-width: 1100px) {
    .footer-grid { grid-template-columns: repeat(2, 1fr); gap: 36px; }
  }
  @media (max-width: 768px) {
    .footer-grid { grid-template-columns: 1fr; gap: 32px; }
    .site-footer { padding-bottom: 80px; } /* space for mobile CTA bar */
  }
</style>
