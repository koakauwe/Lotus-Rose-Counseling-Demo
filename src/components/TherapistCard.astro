---
interface Props {
  name: string;
  title: string;
  specialties: string[];
  bio: string;
  photo?: string;
  languages?: string;
  telehealth?: boolean;
  bookingText?: string;
  bookingUrl?: string;
}

const {
  name,
  title,
  specialties,
  bio,
  photo,
  languages,
  telehealth,
  bookingText = "Book an Appointment",
  bookingUrl = "/contact/"
} = Astro.props;
---

<div class="therapist-card">
  <div class="therapist-card-photo">
    {photo ? (
      <img src={photo} alt={`${name} — therapist at Lotus Rose Counseling in Orem, Utah`} class="therapist-photo-img" width="200" height="200" loading="lazy" />
    ) : (
      <div class="therapist-photo-circle">
        <span>{name.split(' ')[0]}</span>
      </div>
    )}
  </div>
  <div class="therapist-card-info">
    <h3 class="therapist-name">{name}</h3>
    <p class="therapist-title">
      {title}
      {languages && <span> · {languages}</span>}
      {telehealth && <span> · Telehealth Only</span>}
    </p>
    <ul class="specialties-list">
      {specialties.map(s => <li>{s}</li>)}
    </ul>
    <p class="therapist-bio">{bio}</p>
    <a href={bookingUrl} class="btn-primary therapist-cta">{bookingText}</a>
  </div>
</div>

<style>
  .therapist-card {
    display: flex;
    gap: 40px;
    align-items: flex-start;
    padding: 48px;
    background: var(--white);
    border-radius: 16px;
    box-shadow: var(--shadow-soft);
    margin-bottom: 32px;
  }
  .therapist-photo-img {
    width: 200px;
    height: 200px;
    border-radius: 50%;
    object-fit: cover;
    flex-shrink: 0;
    border: 4px solid var(--soft-rose);
    box-shadow: var(--shadow-soft);
  }
  .therapist-photo-circle {
    width: 200px;
    height: 200px;
    border-radius: 50%;
    background: var(--gradient-hero);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    font-size: 16px;
    color: var(--text-medium);
    border: 4px solid var(--soft-rose);
    box-shadow: var(--shadow-soft);
  }
  .therapist-card-info { flex: 1; }
  .therapist-bio {
    font-size: 16px;
    line-height: 1.8;
    margin-bottom: 24px;
  }
  .therapist-cta {
    padding: 14px 32px;
    font-size: 15px;
  }

  @media (max-width: 768px) {
    .therapist-card {
      flex-direction: column;
      align-items: center;
      text-align: center;
      padding: 32px 24px;
      gap: 24px;
    }
    .therapist-photo-img { width: 160px; height: 160px; }
    .therapist-photo-circle { width: 160px; height: 160px; }
    .specialties-list { justify-content: center; }
  }
</style>
