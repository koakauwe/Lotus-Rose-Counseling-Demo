---
interface Props {
  name: string;
  title: string;
  specialties: string[];
  bio: string;
  photo?: string;
  profileUrl?: string;
  languages?: string;
  telehealth?: boolean;
  bookingText?: string;
  bookingUrl?: string;
}

const {
  name,
  title,
  specialties,
  bio,
  photo,
  profileUrl,
  languages,
  telehealth,
  bookingText = "Book an Appointment",
  bookingUrl = "/contact/"
} = Astro.props;

// Map specialty names to modality pages. Case-insensitive, trimmed.
// Also handles common variants (e.g., "Postpartum Depression/Anxiety" -> PPD page).
const modalityMap: Record<string, string> = {
  // Modalities
  "emdr": "/emdr-therapy/",
  "accelerated resolution therapy": "/accelerated-resolution-therapy/",
  "art": "/accelerated-resolution-therapy/",
  "internal family systems": "/modalities/internal-family-systems/",
  "ifs": "/modalities/internal-family-systems/",
  "cbt": "/modalities/cognitive-behavioral-therapy/",
  "cognitive behavioral therapy": "/modalities/cognitive-behavioral-therapy/",
  "dbt": "/modalities/dialectical-behavior-therapy/",
  "dialectical behavior therapy": "/modalities/dialectical-behavior-therapy/",
  "act": "/modalities/acceptance-commitment-therapy/",
  "acceptance and commitment therapy": "/modalities/acceptance-commitment-therapy/",
  "eft": "/modalities/emotionally-focused-therapy/",
  "emotionally focused therapy": "/modalities/emotionally-focused-therapy/",
  "experiential": "/modalities/experiential-therapy/",
  "experiential therapy": "/modalities/experiential-therapy/",

  // Conditions (link to service pages)
  "postpartum depression": "/postpartum-depression/",
  "postpartum depression/anxiety": "/postpartum-depression/",
  "postpartum": "/postpartum-depression/",
  "perinatal mood disorders": "/postpartum-depression/",
  "trauma": "/trauma-therapy/",
  "ptsd": "/trauma-therapy/",
  "trauma & ptsd": "/trauma-therapy/",
  "anxiety": "/anxiety-depression/",
  "depression": "/anxiety-depression/",
  "anxiety & depression": "/anxiety-depression/",
  "grief": "/grief-counseling/",
  "grief & loss": "/grief-counseling/",
  "grief counseling": "/grief-counseling/",
};

function getModalityUrl(specialty: string): string | null {
  const key = specialty.toLowerCase().trim();
  return modalityMap[key] || null;
}
---

<div class="therapist-card">
  <div class="therapist-card-photo">
    {profileUrl ? (
      <a href={profileUrl}>
        {photo ? (
          <img src={photo} alt={`${name} — therapist at Lotus Rose Counseling in Orem, Utah`} class="therapist-photo-img" width="200" height="200" loading="lazy" />
        ) : (
          <div class="therapist-photo-circle">
            <span>{name.split(' ')[0]}</span>
          </div>
        )}
      </a>
    ) : (
      photo ? (
        <img src={photo} alt={`${name} — therapist at Lotus Rose Counseling in Orem, Utah`} class="therapist-photo-img" width="200" height="200" loading="lazy" />
      ) : (
        <div class="therapist-photo-circle">
          <span>{name.split(' ')[0]}</span>
        </div>
      )
    )}
  </div>
  <div class="therapist-card-info">
    <h3 class="therapist-name">{name}</h3>
    <p class="therapist-title">
      {title}
      {languages && <span> · {languages}</span>}
      {telehealth && <span> · Telehealth Only</span>}
    </p>
    <ul class="specialties-list">
      {specialties.map(s => {
        const url = getModalityUrl(s);
        return url
          ? <li class="specialty-link-wrap"><a href={url} class="specialty-link">{s}</a></li>
          : <li>{s}</li>;
      })}
    </ul>
    <p class="therapist-bio">{bio}</p>
    <div class="therapist-actions">
      <a href={bookingUrl} class="btn-primary therapist-cta">{bookingText}</a>
      {profileUrl && <a href={profileUrl} class="therapist-profile-link">Read full profile →</a>}
    </div>
  </div>
</div>

<style>
  .therapist-card {
    display: flex;
    gap: 40px;
    align-items: flex-start;
    padding: 48px;
    background: var(--white);
    border-radius: 16px;
    box-shadow: var(--shadow-soft);
    margin-bottom: 32px;
  }
  :global(.therapist-floral) .therapist-card {
    background: rgba(255, 248, 243, 0.88);
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
    margin-bottom: 0;
  }
  .therapist-photo-img {
    width: 200px;
    height: 200px;
    border-radius: 50%;
    object-fit: cover;
    flex-shrink: 0;
    border: 4px solid var(--soft-rose);
    box-shadow: var(--shadow-soft);
  }
  .therapist-photo-circle {
    width: 200px;
    height: 200px;
    border-radius: 50%;
    background: var(--blush-pink);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    font-size: 16px;
    color: var(--text-medium);
    border: 4px solid var(--soft-rose);
    box-shadow: var(--shadow-soft);
  }
  .therapist-card-info { flex: 1; }
  .therapist-bio {
    font-size: 16px;
    line-height: 1.8;
    margin-bottom: 24px;
  }
  .therapist-actions {
    display: flex;
    align-items: center;
    gap: 20px;
    flex-wrap: wrap;
  }
  .therapist-cta {
    padding: 14px 32px;
    font-size: 15px;
  }
  .therapist-profile-link {
    font-weight: 700;
    font-size: 15px;
    color: var(--peach-gold);
  }
  .therapist-profile-link:hover {
    color: var(--text-dark);
  }

  @media (max-width: 768px) {
    .therapist-card {
      flex-direction: column;
      align-items: center;
      text-align: center;
      padding: 32px 24px;
      gap: 24px;
    }
    .therapist-photo-img { width: 160px; height: 160px; }
    .therapist-photo-circle { width: 160px; height: 160px; }
    .specialties-list { justify-content: center; }
  }
</style>
