---
import BaseLayout from '../layouts/BaseLayout.astro';

const faqSchema = [
  {
    question: "What insurances does Lotus Rose Counseling accept?",
    answer: "We accept Select Health, United Health, PEHP, DMBA, EMI, and BCBS (Blue Cross Blue Shield). Contact us to verify your specific plan and benefits before your first session."
  },
  {
    question: "How much does therapy cost without insurance?",
    answer: "Self-pay rates are $180 for the initial intake (first session) and $125 to $150 for ongoing sessions, depending on the therapist's license level. We want therapy to be accessible, so we're happy to talk through options during your free 15-minute consultation."
  },
  {
    question: "Do you offer a free consultation?",
    answer: "Yes. We offer a free 15-minute phone consultation so you can ask questions, discuss what you're going through, and determine if Lotus Rose is the right fit before committing to a full session."
  }
];
---

<BaseLayout
  title="Insurance & Pricing | Lotus Rose Counseling in Orem, UT"
  description="Lotus Rose Counseling in Orem accepts Select Health, United Health, PEHP, DMBA, EMI, and BCBS. Self-pay options also available. Free 15-minute consultation."
  faqSchema={faqSchema}
>

  <!-- No hero — straight to content per checklist #39 -->
  <section class="insurance-top bg-white">
    <div class="container">
      <div class="text-container">
        <p class="section-label">Insurance & Pricing</p>
        <h1>Making Therapy Accessible</h1>
        <p>We believe financial barriers shouldn't prevent you from getting the help you need. Lotus Rose Counseling accepts most major insurance plans and offers a free consultation to help you understand your coverage.</p>
      </div>
    </div>
  </section>

  <section class="bg-white" style="padding-top: 20px;">
    <div class="container">
      <div class="text-container">
        <div class="highlight-box">
          <h3>Insurances We Accept</h3>
          <p>Lotus Rose Counseling is in-network with the following insurance plans:</p>
          <ul class="insurance-list">
            <li><strong>Select Health</strong></li>
            <li><strong>United Health</strong></li>
            <li><strong>PEHP</strong> (Public Employees Health Program)</li>
            <li><strong>DMBA</strong> (Deseret Mutual Benefit Administrators)</li>
            <li><strong>EMI</strong> (Educators Mutual Insurance)</li>
            <li><strong>BCBS</strong> (Blue Cross Blue Shield)</li>
          </ul>
          <p>To verify your specific plan and benefits, call us at <a href="tel:+18016424244">(801) 642-4244</a> or fill out our <a href="/contact/">contact form</a> and select "Insurance coverage question." Have your insurance card ready and we'll help verify your benefits.</p>
        </div>

        <h2>What to Know Before Your First Session</h2>

        <h3>Free 15-Minute Consultation</h3>
        <p>Every new client starts with a free phone consultation. This isn't a sales pitch — it's a chance for you to ask questions, describe what you're going through, and see if Lotus Rose feels like the right fit. No commitment required.</p>

        <h3>Understanding Your Benefits</h3>
        <p>Insurance coverage for therapy varies by plan. Some things to check:</p>
        <ul style="padding-left: 24px; margin-bottom: 24px;">
          <li style="margin-bottom: 8px;">Does your plan cover outpatient mental health services?</li>
          <li style="margin-bottom: 8px;">What is your copay or coinsurance for therapy visits?</li>
          <li style="margin-bottom: 8px;">Do you need a referral from your primary care provider?</li>
          <li style="margin-bottom: 8px;">Is there a deductible that applies to mental health services?</li>
          <li style="margin-bottom: 8px;">Is there a limit on the number of sessions per year?</li>
        </ul>
        <p>We can help you navigate these questions — just ask during your consultation or contact us beforehand.</p>

        <h3>Self-Pay Pricing</h3>
        <p>If you don't have insurance, prefer to pay out of pocket, or your plan isn't one we accept, self-pay is available. Our rates reflect the level of training and licensure of each therapist.</p>

        <div class="pricing-grid">
          <div class="pricing-card">
            <p class="pricing-label">Initial Intake</p>
            <p class="pricing-amount">$180</p>
            <p class="pricing-note">First session, includes assessment and treatment planning</p>
          </div>
          <div class="pricing-card">
            <p class="pricing-label">Ongoing Sessions</p>
            <p class="pricing-amount">$125&ndash;$150</p>
            <p class="pricing-note">Per session, depending on therapist license level</p>
          </div>
        </div>

        <p>A few advantages of paying out of pocket:</p>
        <ul style="padding-left: 24px; margin-bottom: 24px;">
          <li style="margin-bottom: 8px;">No diagnosis required on your permanent medical record</li>
          <li style="margin-bottom: 8px;">No session limits imposed by insurance</li>
          <li style="margin-bottom: 8px;">Complete privacy — no insurance company involved in your treatment</li>
        </ul>

        <h3>Cancellation Policy</h3>
        <p>We ask for 24 hours' notice if you need to cancel or reschedule. Late cancellations and no-shows may be subject to a fee. We understand life happens — especially for moms — so please communicate with us and we'll work with you.</p>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="bg-cream">
    <div class="container">
      <div class="text-container text-center">
        <p class="section-label">Common Questions</p>
        <h2>Insurance & Pricing FAQs</h2>
      </div>
      <div class="faq-section">
        {faqSchema.map(faq => (
          <details class="faq-item">
            <summary>{faq.question}</summary>
            <div class="faq-answer"><p>{faq.answer}</p></div>
          </details>
        ))}
      </div>
      <div class="faq-link">
        <a href="/contact/">Have another question? Reach out →</a>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="cta-section">
    <div class="container">
      <h2>Ready to Get Started?</h2>
      <p>Schedule a free 15-minute consultation and we'll help you understand your coverage and find the right therapist.</p>
      <a href="/contact/" class="btn-primary">Schedule Free Consultation</a>
    </div>
  </section>

</BaseLayout>

<style>
  .insurance-top { padding: 80px 0 20px; }
  .insurance-list {
    columns: 2;
    column-gap: 32px;
    padding-left: 0;
    list-style: none;
    margin: 16px 0 24px;
  }
  .insurance-list li {
    padding: 8px 0 8px 24px;
    position: relative;
    break-inside: avoid;
    color: var(--text-medium);
  }
  .insurance-list li::before {
    content: "✓";
    position: absolute;
    left: 0;
    color: var(--peach-gold);
    font-weight: 700;
  }
  .insurance-list li strong {
    color: var(--text-dark);
  }

  .pricing-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 20px;
    margin: 24px 0 32px;
  }
  .pricing-card {
    background: var(--warm-cream);
    border-left: 3px solid var(--peach-gold);
    border-radius: 0 12px 12px 0;
    padding: 24px 28px;
    text-align: left;
  }
  .pricing-label {
    font-size: 13px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    color: var(--peach-gold);
    margin: 0 0 6px;
  }
  .pricing-amount {
    font-family: var(--font-heading);
    font-size: 36px;
    font-weight: 700;
    color: var(--text-dark);
    margin: 0 0 8px;
    line-height: 1;
  }
  .pricing-note {
    font-size: 14px;
    color: var(--text-medium);
    margin: 0;
    line-height: 1.5;
  }

  @media (max-width: 768px) {
    .insurance-top { padding: 60px 0 10px; }
    .insurance-list { columns: 1; }
    .pricing-grid { grid-template-columns: 1fr; gap: 16px; }
    .pricing-amount { font-size: 32px; }
  }
</style>
