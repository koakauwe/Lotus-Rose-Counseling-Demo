<style>
  .legal-page { padding: 80px 0; }
  .legal-page h1 { margin-bottom: 8px; }
  .legal-updated { font-size: 14px; color: var(--text-light); margin-bottom: 40px; }
  .legal-page h2 { margin-top: 40px; font-size: 28px; }
  .legal-page ul { padding-left: 24px; margin-bottom: 20px; }
  .legal-page li { margin-bottom: 8px; color: var(--text-medium); }
</style>
