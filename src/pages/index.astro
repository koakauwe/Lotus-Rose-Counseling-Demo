---
import BaseLayout from '../layouts/BaseLayout.astro';

const faqSchema = [
  {
    question: "What types of therapy does Lotus Rose Counseling offer?",
    answer: "Lotus Rose Counseling specializes in perinatal mental health (postpartum depression, birth trauma, infant loss), childhood abuse recovery, trauma and PTSD therapy, grief counseling, and women's mental health in general — including navigating difficult relationships, abuse, and life transitions. All therapists are trained in trauma treatment modalities like EMDR, ART, IFS, and experiential therapy."
  },
  {
    question: "What makes Lotus Rose different from other therapy practices?",
    answer: "Women's mental health is our core specialty — not a side offering alongside everything else. As Joy puts it: 'A lot of places will say they see women, but they have a wide variety of what they see. With us, women's mental health is what we do.' Every training the team takes is specifically geared toward women's issues, and the space was designed to feel like a safe haven for women who've experienced traumatic events."
  },
  {
    question: "How do I know if I need therapy?",
    answer: "As Joy says, 'You don't know you need it until you know.' Many women come in for postpartum depression and discover unprocessed childhood experiences underneath. If you're struggling with persistent sadness, anxiety, intrusive thoughts, difficulty bonding with your baby, grief, or trauma — therapy can help. You don't need to be in crisis. A free 15-minute consultation is a low-pressure way to find out."
  },
  {
    question: "What does therapy at Lotus Rose actually look like?",
    answer: "Most clients work with their therapist for 6-12 months. The first phase focuses on building a genuine relationship, education, and getting comfortable. Then the deeper processing work begins. Joy describes her approach as open and honest, with room for humor — because the topics are hard, and the space needs to feel human. You're never locked into a contract."
  },
  {
    question: "Where is Lotus Rose Counseling located?",
    answer: "Lotus Rose Counseling is located at 237 W. 520 N. St in Orem, Utah, in a cozy basement office under Forever by Ash. We serve clients throughout Utah County including Provo, Lehi, American Fork, Pleasant Grove, Lindon, and Vineyard. Telehealth sessions are also available."
  },
  {
    question: "I'm nervous about starting therapy. What should I do?",
    answer: "Call and ask for a free 15-minute consultation. You can meet a clinician over telehealth, ask about their approach and training, see what they're like as a person. As Joy puts it: 'Sometimes just having that initial conversation opens the door.' There's no commitment — you can come to a session and if it's not the right fit, find somewhere else. No contract, no pressure."
  }
];
---

<BaseLayout
  title="Mental Health Therapy for Women & Teens in Orem, UT | Lotus Rose Counseling"
  description="Lotus Rose Counseling offers EMDR, trauma therapy, postpartum depression treatment, and grief counseling for women, teens, and children in Orem and Utah County."
  faqSchema={faqSchema}
>

  <!-- ===== FULL-BLEED HERO — Floral Peonies ===== -->
  <section class="hero-fullbleed">
    <div class="hero-fullbleed-bg">
      <img src="/florals/hero-peonies.jpg" alt="White peonies — Lotus Rose Counseling" width="1920" height="1080" fetchpriority="high" />
    </div>
    <div class="hero-fullbleed-overlay"></div>
    <div class="hero-fullbleed-content">
      <p class="section-label">Mental Health Therapy in Orem, Utah</p>
      <h1>A Safe Place to Heal, Grow, and Bloom</h1>
      <p class="hero-subtitle">A safe haven for women navigating postpartum depression, birth trauma, childhood abuse, grief, and life's hardest chapters.</p>
      <div class="btn-group" style="justify-content: center;">
        <a href="/contact/" class="btn-primary">Schedule a Free Consultation</a>
        <a href="/services/" class="btn-secondary">Explore Our Services</a>
      </div>
      <div class="hero-trust">
        <span class="trust-item">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
          Insurance Accepted
        </span>
        <span class="trust-item">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
          In-Person & Telehealth
        </span>
        <span class="trust-item">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
          Free 15-Min Consultation
        </span>
      </div>
    </div>
  </section>

  <!-- ===== SPLIT: Joy's Story (text left, photo right) ===== -->
  <div class="split-section">
    <div class="split-content">
      <p class="section-label">Why Lotus Rose</p>
      <h2>Built by a Woman Who Knows What It's Like</h2>
      <p>Joy Bouchard founded Lotus Rose because she's lived the struggle. As a mom of three, she has her own journey with birth trauma, postpartum depression, and postpartum anxiety — each child bringing a different experience.</p>
      <p>She knows what it's like to need someone to talk to during the hardest chapters of motherhood. She wanted to create a place that felt genuinely safe — especially for women who've experienced traumatic events.</p>
      <a href="/about/" class="btn-secondary" style="margin-top: 16px; align-self: flex-start;">Read Our Story →</a>
    </div>
    <div class="split-image">
      <img src="/photos/joy-bouchard.jpg" alt="Joy Bouchard, LCSW — founder of Lotus Rose Counseling" width="800" height="800" loading="lazy" />
    </div>
  </div>

  <!-- ===== SPLIT REVERSE: What Makes Us Different (photo left, text right) ===== -->
  <div class="split-section split-section--reverse">
    <div class="split-content">
      <p class="section-label">What Makes Us Different</p>
      <h2>Women's Mental Health Is Our Specialty. It's What We Do Best.</h2>
      <p>A lot of practices say they see women for postpartum or perinatal issues — but they also see everyone else for everything else. At Lotus Rose, women's mental health is our core focus. We also work with teens and children — especially those navigating grief, trauma, and behavioral challenges.</p>
      <p>Every therapist is trained in trauma treatment. Every continuing education course is chosen specifically for women's issues. The space itself was designed to feel like a safe haven — warm, welcoming, and nothing like a clinical office.</p>
    </div>
    <div class="split-image">
      <img src="/photos/office-3.jpg" alt="Warm therapy space at Lotus Rose Counseling" width="800" height="600" loading="lazy" />
    </div>
  </div>

  <!-- ===== PULL QUOTE — Floral Background ===== -->
  <section class="floral-section floral-subtle" style="padding: 100px 0;">
    <div class="container">
      <div class="floral-content" style="margin: 0 auto;">
        <div class="pull-quote" style="margin: 0;">
          <p>"You don't know you need it until you know. People would come in for postpartum depression, and we'd find there's a lot of stuff from childhood they hadn't processed yet. The two really overlap."</p>
          <cite>Joy Bouchard, LCSW — Founder</cite>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== THERAPISTS ===== -->
  <section class="bg-white">
    <div class="container">
      <div class="text-container text-center">
        <p class="section-label">Your Therapists</p>
        <h2>Meet the Team Behind Lotus Rose</h2>
        <p>Four therapists, each bringing different specialties and a shared commitment: every training they take is geared toward the things they're most passionate about — women's mental health.</p>
      </div>
      <div class="therapist-preview-grid">
        <div class="therapist-preview">
          <img src="/photos/joy-bouchard.jpg" alt="Joy Bouchard, LCSW — owner and therapist at Lotus Rose Counseling" class="therapist-photo" width="160" height="160" loading="lazy" />
          <h3 class="therapist-name">Joy Bouchard</h3>
          <p class="therapist-title">Owner & LCSW</p>
          <p>EMDR, ART, IFS, Postpartum, Birth Trauma, Infant Loss, Childhood Abuse</p>
        </div>
        <div class="therapist-preview">
          <img src="/photos/megan-judd.jpg" alt="Megan Judd — therapist at Lotus Rose Counseling" class="therapist-photo" width="160" height="160" loading="lazy" />
          <h3 class="therapist-name">Megan Judd</h3>
          <p class="therapist-title">Therapist</p>
          <p>EMDR, IFS, Trauma, PTSD, Anxiety, Depression, Faith Transitions</p>
        </div>
        <div class="therapist-preview">
          <img src="/photos/pam-basinger.jpg" alt="Pam Basinger — bilingual therapist at Lotus Rose Counseling" class="therapist-photo" width="160" height="160" loading="lazy" />
          <h3 class="therapist-name">Pam Basinger</h3>
          <p class="therapist-title">Therapist · Español · Português</p>
          <p>ART, ADHD, Grief, Life Transitions, Oppositional Defiance</p>
        </div>
        <div class="therapist-preview">
          <img src="/photos/brynnlee-brunt.jpg" alt="Brynnlee Brunt — telehealth therapist at Lotus Rose Counseling" class="therapist-photo" width="160" height="160" loading="lazy" />
          <h3 class="therapist-name">Brynnlee Brunt</h3>
          <p class="therapist-title">Therapist · Telehealth Only</p>
          <p>CBT, EMDR, EFT, Infertility, Postpartum, Anxiety</p>
        </div>
      </div>
      <div class="text-center" style="margin-top: 36px;">
        <a href="/our-therapists/" class="btn-secondary">Meet Our Full Team →</a>
      </div>
    </div>
  </section>

  <!-- ===== SPLIT: Services (text left, photo right) ===== -->
  <div class="split-section">
    <div class="split-content">
      <p class="section-label">How We Help</p>
      <h2>Evidence-Based Therapy Matched to Your Needs</h2>
      <p style="margin-bottom: 28px;">We don't use one-size-fits-all approaches. Your therapist assesses your specific situation and uses the modalities that will be most effective for you.</p>
      <ul class="services-list">
        <li><a href="/postpartum-depression/">Postpartum Depression <span class="arrow">→</span></a></li>
        <li><a href="/emdr-therapy/">EMDR Therapy <span class="arrow">→</span></a></li>
        <li><a href="/accelerated-resolution-therapy/">Accelerated Resolution Therapy <span class="arrow">→</span></a></li>
        <li><a href="/grief-counseling/">Grief & Loss Counseling <span class="arrow">→</span></a></li>
        <li><a href="/trauma-therapy/">Trauma & PTSD <span class="arrow">→</span></a></li>
        <li><a href="/anxiety-depression/">Anxiety & Depression <span class="arrow">→</span></a></li>
      </ul>
    </div>
    <div class="split-image">
      <img src="/photos/office-2.jpg" alt="Comfortable therapy space at Lotus Rose Counseling" width="800" height="600" loading="lazy" />
    </div>
  </div>

  <!-- ===== TESTIMONIALS — Real Google Reviews ===== -->
  <section class="bg-cream">
    <div class="container">
      <div class="text-container text-center">
        <p class="section-label">Google Reviews</p>
        <h2>5 Stars From Real Clients</h2>
      </div>
      <div class="testimonial-grid" style="margin-top: 40px;">
        <div class="testimonial-card">
          <div class="testimonial-stars">★★★★★</div>
          <p class="testimonial-quote">"Joy is an AMAZING therapist who has truly made a huge positive impact on my life. Her compassion, deep understanding, insightfulness, and skills have helped me navigate some insane challenges with confidence."</p>
          <p class="testimonial-author">— Rebecca B.</p>
        </div>
        <div class="testimonial-card">
          <div class="testimonial-stars">★★★★★</div>
          <p class="testimonial-quote">"Megan has really helped and done amazing work with EMDR that I've seen immediate results from, it's changing my life. Every area of my life has improved, especially my relationship with myself."</p>
          <p class="testimonial-author">— Olivia W.</p>
        </div>
        <div class="testimonial-card">
          <div class="testimonial-stars">★★★★★</div>
          <p class="testimonial-quote">"Our 14 yr old feels so comfortable talking to Joy. She feels heard and seen. Joy is such a blend of fun, relatable, good listener and validator, and also knows how to give tips and tools that are so needed."</p>
          <p class="testimonial-author">— Ally D.</p>
        </div>
        <div class="testimonial-card">
          <div class="testimonial-stars">★★★★★</div>
          <p class="testimonial-quote">"I'm a psychiatric provider in a women's health clinic. I refer patients to this clinic at least once a day. My patients have always reported back that the therapists are amazing and that they find real healing there."</p>
          <p class="testimonial-author">— Aimee H.</p>
        </div>
        <div class="testimonial-card">
          <div class="testimonial-stars">★★★★★</div>
          <p class="testimonial-quote">"Joy is absolutely phenomenal. It feels like you're just gabbing with a friend, but by the end of every appointment, I've left feeling prepared, encouraged, and hopeful. She's like a warm hug you didn't know you needed!"</p>
          <p class="testimonial-author">— Samantha P.</p>
        </div>
        <div class="testimonial-card">
          <div class="testimonial-stars">★★★★★</div>
          <p class="testimonial-quote">"Pam was absolutely amazing. She spent time with me and really listened to my concerns. I've never had a therapist as caring and attentive. She's incredible!"</p>
          <p class="testimonial-author">— Tiffani H.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== WHAT TO EXPECT — Floral Background ===== -->
  <section class="floral-section floral-contact" style="padding: 100px 0;">
    <div class="container">
      <div class="floral-content">
        <p class="section-label">What to Expect</p>
        <h2>Therapy Isn't What You Think It Is</h2>
        <p>One of the biggest misconceptions Joy hears is that therapy is just talking — something you could do with a friend. There's training, technique, and years of dedication behind every session.</p>
        <p>The other myth? That it's a fast fix. Healing takes time. Most clients work with their therapist for 6-12 months. The first phase is about building genuine rapport and getting comfortable. Then the deep work begins.</p>
        <p>Joy keeps it human: open dialog, education, and yes — humor. Because the topics are hard, and the space needs to feel real.</p>
        <a href="/contact/" class="btn-primary" style="margin-top: 20px;">Book Free Consultation</a>
      </div>
    </div>
  </section>

  <!-- ===== FAQ ===== -->
  <section class="bg-cream">
    <div class="container">
      <div class="text-container text-center">
        <p class="section-label">Common Questions</p>
        <h2>Frequently Asked Questions</h2>
      </div>
      <div class="faq-section">
        {faqSchema.map(faq => (
          <details class="faq-item">
            <summary>{faq.question}</summary>
            <div class="faq-answer">
              <p>{faq.answer}</p>
            </div>
          </details>
        ))}
      </div>
      <div class="faq-link">
        <a href="/contact/">Have another question? Reach out →</a>
      </div>
    </div>
  </section>

  <!-- ===== CTA ===== -->
  <section class="cta-section">
    <div class="container">
      <h2>Ready to Start Feeling Like Yourself Again?</h2>
      <p>Your first step is a free 15-minute consultation. No pressure, no commitment — just a conversation about what you're going through and how we might help.</p>
      <div class="btn-group" style="justify-content: center;">
        <a href="/contact/" class="btn-primary">Schedule Free Consultation</a>
        <a href="tel:+18016424244" class="btn-secondary">Call (801) 642-4244</a>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  /* Therapist Preview Grid */
  .therapist-preview-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 32px;
    margin-top: 48px;
    text-align: center;
  }
  .therapist-preview p {
    font-size: 14px;
    line-height: 1.6;
  }
  .therapist-preview .therapist-photo {
    width: 160px;
    height: 160px;
    border-radius: 50%;
    object-fit: cover;
    margin: 0 auto 20px;
    border: 4px solid var(--soft-rose);
    box-shadow: var(--shadow-soft);
  }
  .therapist-preview .therapist-name {
    font-size: 26px;
    margin-bottom: 4px;
  }

  @media (max-width: 1100px) {
    .therapist-preview-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 768px) {
    .therapist-preview-grid { grid-template-columns: 1fr; }
  }
</style>
