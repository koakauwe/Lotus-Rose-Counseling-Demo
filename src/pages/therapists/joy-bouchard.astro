---
import BaseLayout from '../../layouts/BaseLayout.astro';

const faqSchema = [
  {
    question: "What does Joy Bouchard specialize in?",
    answer: "Joy specializes in perinatal mental health (postpartum depression, birth trauma, infant loss), childhood abuse recovery — especially when it resurfaces during motherhood — and grief and loss. She uses EMDR, Accelerated Resolution Therapy (ART), Internal Family Systems (IFS), and experiential therapy."
  },
  {
    question: "Is Joy Bouchard accepting new clients?",
    answer: "Joy currently has a waitlist. You can join the waitlist by calling (801) 642-4244 or filling out the contact form. In the meantime, our other therapists at Lotus Rose may have availability and share similar training. We can help you find the right fit during a free 15-minute consultation."
  },
  {
    question: "What is Joy's approach to therapy?",
    answer: "Joy prioritizes building genuine rapport first — she believes the therapeutic relationship is the foundation for everything. She describes her style as open and honest, with room for humor, because the topics are hard and the space needs to feel human. She provides a lot of education early on to help clients understand what they're experiencing."
  }
];
---

<BaseLayout
  title="Joy Bouchard, LCSW — Therapist in Orem, UT | Lotus Rose Counseling"
  description="Joy Bouchard is a Licensed Clinical Social Worker and founder of Lotus Rose Counseling in Orem, Utah. She specializes in EMDR, postpartum depression, birth trauma, infant loss, and childhood abuse recovery."
  faqSchema={faqSchema}
>

  <!-- Hero -->
  <section class="hero-fullbleed">
    <div class="hero-fullbleed-bg">
      <img src="/florals/floral-joy.jpg" alt="Floral background — Joy Bouchard, LCSW" width="1920" height="1080" fetchpriority="high" />
    </div>
    <div class="hero-fullbleed-overlay"></div>
    <div class="hero-fullbleed-content">
      <p class="section-label">Meet Your Therapist</p>
      <h1>Joy Bouchard, LCSW</h1>
      <p class="hero-subtitle">Owner & Licensed Clinical Social Worker</p>
    </div>
  </section>

  <!-- Profile -->
  <div class="split-section">
    <div class="split-content">
      <div class="therapist-detail-meta">
        <span class="detail-badge">Founder & Owner</span>
        <span class="detail-badge">Currently Waitlisted</span>
      </div>
      <h2>Why Joy Became a Therapist</h2>
      <p>Joy chose this profession because she knows what it's like to go through the hardest chapters of life — specifically grief, loss, and postpartum mental health challenges. As a mother of three, she has her own journey with birth trauma, postpartum depression, and postpartum anxiety. Each child brought a different experience.</p>
      <p>She knows what it's like to need someone to talk to, someone who can guide you through navigating the hardest periods of motherhood. That's why she created Lotus Rose — not just a specialized practice, but a place that feels genuinely safe for women who've experienced traumatic events.</p>
    </div>
    <div class="split-image">
      <img src="/photos/joy-bouchard.jpg" alt="Joy Bouchard, LCSW — founder of Lotus Rose Counseling in Orem, Utah" width="800" height="800" loading="lazy" />
    </div>
  </div>

  <!-- What She Treats -->
  <section class="bg-cream">
    <div class="container">
      <div class="text-container">
        <p class="section-label">Specialties</p>
        <h2>What Joy Is Most Passionate About</h2>

        <p>Joy's deepest passions and favorite things to treat are helping women with <strong>birth trauma, infant loss, and childhood abuse</strong>. She holds space with care and tenderness, drawing from both clinical training and her own life experience.</p>

        <div class="highlight-box">
          <h4>Conditions Joy Treats</h4>
          <ul>
            <li>Birth trauma and traumatic birth experiences</li>
            <li>Infant loss and pregnancy loss</li>
            <li>Childhood abuse recovery (physical, sexual, emotional)</li>
            <li>Postpartum depression, anxiety, and OCD</li>
            <li>Developmental trauma and complex PTSD</li>
            <li>Grief and loss</li>
            <li>Perfectionism and identity struggles</li>
          </ul>
        </div>

        <p><strong>Licensure:</strong> Joy is a Licensed Clinical Social Worker (LCSW) in Utah and Nebraska.</p>
      </div>
    </div>
  </section>

  <!-- Modalities -->
  <section class="bg-white">
    <div class="container">
      <div class="text-container">
        <p class="section-label">Therapeutic Approach</p>
        <h2>How Joy Works</h2>
        <p>Joy prioritizes building genuine rapport before diving into the deep work. She believes the therapeutic relationship is the foundation for everything that follows. Her style is open and honest, with room for humor — because the topics are hard, and the space needs to feel human.</p>
        <p>Most of her clients work with her for 6-12 months. The first phase focuses on education, building trust, and getting comfortable. Then the deeper processing work begins.</p>

        <div class="highlight-box">
          <h4>Training & Modalities</h4>
          <ul>
            <li><a href="/emdr-therapy/">EMDR (Eye Movement Desensitization and Reprocessing)</a></li>
            <li><a href="/accelerated-resolution-therapy/">ART (Accelerated Resolution Therapy)</a></li>
            <li><a href="/modalities/internal-family-systems/">IFS (Internal Family Systems)</a></li>
            <li><a href="/modalities/experiential-therapy/">Experiential Therapy</a></li>
            <li>Self-Compassion techniques</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Quote -->
  <div class="statement-section">
    <p>"I wanted to create a place that was very safe, that felt warm and welcoming. All of our clinicians are trained in how to help specifically with women's issues. I wanted it to be a safe haven."<br><span class="statement-accent">— Joy Bouchard</span></p>
  </div>

  <!-- FAQ -->
  <section class="bg-cream">
    <div class="container">
      <div class="text-container text-center">
        <p class="section-label">Common Questions</p>
        <h2>About Joy</h2>
      </div>
      <div class="faq-section">
        {faqSchema.map(faq => (
          <details class="faq-item">
            <summary>{faq.question}</summary>
            <div class="faq-answer"><p>{faq.answer}</p></div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="cta-section">
    <div class="container">
      <h2>Want to Work With Joy?</h2>
      <p>Joy currently has a waitlist. Call to join, or schedule a free consultation to find the right therapist match at Lotus Rose.</p>
      <div class="btn-group" style="justify-content: center;">
        <a href="/contact/" class="btn-primary">Schedule Free Consultation</a>
        <a href="tel:+18016424244" class="btn-secondary">Call (801) 642-4244</a>
      </div>
    </div>
  </section>

  <!-- Person Schema -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Person",
    "@id": "https://lotusrosecounseling.com/#joy-bouchard",
    "name": "Joy Bouchard",
    "jobTitle": "Licensed Clinical Social Worker",
    "worksFor": { "@id": "https://lotusrosecounseling.com/#business" },
    "knowsAbout": ["EMDR Therapy", "Accelerated Resolution Therapy", "Internal Family Systems", "Experiential Therapy", "Postpartum Depression", "Birth Trauma", "Infant Loss", "Childhood Abuse Recovery", "Grief Counseling"],
    "credential": { "@type": "EducationalOccupationalCredential", "credentialCategory": "license", "name": "Licensed Clinical Social Worker (LCSW)" }
  })} />

</BaseLayout>

<style>
  .therapist-detail-meta {
    display: flex;
    gap: 10px;
    margin-bottom: 20px;
    flex-wrap: wrap;
  }
  .detail-badge {
    display: inline-block;
    padding: 6px 16px;
    border-radius: 50px;
    font-size: 13px;
    font-weight: 700;
    background: var(--panel-bg);
    color: var(--text-dark);
  }
</style>
