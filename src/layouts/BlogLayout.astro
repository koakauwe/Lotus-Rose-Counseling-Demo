---
import BaseLayout from './BaseLayout.astro';

interface FAQItem {
  question: string;
  answer: string;
}

interface Props {
  title: string;
  description: string;
  sectionLabel: string;
  headline: string;
  subtitle: string;
  date: string;
  readTime: string;
  faqSchema: FAQItem[];
  articleSchema: string;
  authorName?: string;
  authorTitle?: string;
  authorBio?: string;
  authorPhoto?: string;
  authorLink?: string;
  ctaLabel?: string;
  ctaHeadline?: string;
  ctaDescription?: string;
}

const {
  title,
  description,
  sectionLabel,
  headline,
  subtitle,
  date,
  readTime,
  faqSchema,
  articleSchema,
  authorName = "Lotus Rose Counseling",
  authorTitle,
  authorBio = "Lotus Rose Counseling is a women's mental health practice in Orem, Utah. Founded by Joy Bouchard, LCSW, the practice specializes in perinatal mental health, trauma, grief, and childhood abuse recovery.",
  authorPhoto,
  authorLink = "/our-therapists/",
  ctaLabel = "Take the First Step",
  ctaHeadline = "Schedule a Free Consultation",
  ctaDescription = "If something in this article resonated with you, a free 15-minute consultation is a low-pressure way to ask questions and see if Lotus Rose is the right fit."
} = Astro.props;
---

<BaseLayout title={title} description={description} faqSchema={faqSchema}>

  <!-- Article Schema -->
  <script type="application/ld+json" set:html={articleSchema} />

  <!-- Blog Hero -->
  <section class="blog-hero">
    <div class="container">
      <a href="/blog/" class="blog-back-link">&larr; Back to Blog</a>
      <p class="section-label">{sectionLabel}</p>
      <h1>{headline}</h1>
      <p class="blog-subtitle"><em>{subtitle}</em></p>
      <div class="blog-meta">
        {authorPhoto && <img src={authorPhoto} alt={authorName} class="byline-photo" width="36" height="36" />}
        <span class="byline-name">{authorName}</span>
        <span class="meta-dot">·</span>
        <span class="blog-date">{date}</span>
        <span class="meta-dot">·</span>
        <span class="blog-read-time">{readTime}</span>
      </div>
    </div>
  </section>

  <!-- At a Glance -->
  <section class="bg-white">
    <div class="container">
      <div class="article-container">
        <div class="glance-box">
          <h2 class="glance-title">At a Glance</h2>
          <slot name="glance" />
        </div>
      </div>
    </div>
  </section>

  <!-- Article Body -->
  <section class="bg-white article-body">
    <div class="container">
      <div class="article-container">
        <slot />
      </div>
    </div>
  </section>

  <!-- FAQ -->
  {faqSchema.length > 0 && (
    <section class="bg-cream">
      <div class="container">
        <div class="article-container">
          <h2 class="faq-heading">Frequently Asked Questions</h2>
          <slot name="faq" />
          <div class="faq-link">
            <a href="/contact/">Have another question? Reach out &rarr;</a>
          </div>
        </div>
      </div>
    </section>
  )}

  <!-- Author Bio -->
  <section class="bg-white">
    <div class="container">
      <div class="article-container">
        <div class="author-box">
          {authorPhoto && (
            <img src={authorPhoto} alt={authorName} class="author-photo" width="100" height="100" />
          )}
          <div class="author-info">
            <p class="author-label">Written by</p>
            <h3 class="author-name">{authorName}</h3>
            {authorTitle && <p class="author-title-text">{authorTitle}</p>}
            <p class="author-bio">{authorBio}</p>
            <a href={authorLink} class="author-link">{authorPhoto ? `More about ${authorName.split(' ')[0]}` : 'Meet our therapists'} &rarr;</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="blog-cta">
    <div class="container">
      <div class="blog-cta-content">
        <p class="section-label">{ctaLabel}</p>
        <h2>{ctaHeadline}</h2>
        <p>{ctaDescription}</p>
        <div class="btn-group" style="justify-content: center;">
          <a href="/contact/" class="btn-primary">Schedule Free Consultation</a>
          <a href="tel:+18016424244" class="btn-secondary">Call (801) 642-4244</a>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  /* Blog Hero */
  .blog-hero {
    background: var(--blush-pink);
    padding: 48px 0 60px;
    text-align: center;
  }
  .blog-back-link {
    display: inline-block;
    font-size: 14px;
    font-weight: 600;
    color: var(--text-medium);
    margin-bottom: 24px;
  }
  .blog-back-link:hover { color: var(--peach-gold); }
  .blog-hero h1 {
    max-width: 800px;
    margin: 0 auto 16px;
    font-size: 44px;
    line-height: 1.15;
  }
  .blog-subtitle {
    font-family: var(--font-heading);
    font-size: 20px;
    color: var(--text-medium);
    max-width: 650px;
    margin: 0 auto 20px;
  }
  .blog-meta {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 12px;
    font-size: 14px;
    color: var(--text-light);
  }
  .byline-photo {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    object-fit: cover;
    border: 2px solid var(--soft-rose);
  }
  .byline-name {
    font-weight: 700;
    color: var(--text-dark);
  }
  .meta-dot { opacity: 0.4; }

  /* Article Container */
  .article-container {
    max-width: 740px;
    margin: 0 auto;
  }

  /* At a Glance */
  .glance-box {
    background: linear-gradient(135deg, rgba(212, 165, 116, 0.08) 0%, rgba(232, 196, 184, 0.12) 100%);
    border-left: 4px solid var(--peach-gold);
    border-radius: 0 12px 12px 0;
    padding: 32px 36px;
  }
  .glance-title {
    font-size: 22px;
    margin-bottom: 16px;
    color: var(--text-dark);
  }
  .glance-box :global(ul) {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .glance-box :global(li) {
    padding: 8px 0 8px 28px;
    position: relative;
    color: var(--text-medium);
    line-height: 1.6;
    font-size: 16px;
  }
  .glance-box :global(li::before) {
    content: '✓';
    position: absolute;
    left: 0;
    color: var(--peach-gold);
    font-weight: 700;
  }

  /* Article Body */
  .article-body {
    padding-top: 20px;
  }
  .article-body :global(h2) {
    font-size: 32px;
    margin-top: 48px;
    margin-bottom: 20px;
  }
  .article-body :global(h3) {
    font-size: 24px;
    margin-top: 36px;
    margin-bottom: 16px;
  }
  .article-body :global(p) {
    font-size: 18px;
    line-height: 1.8;
    margin-bottom: 20px;
  }
  .article-body :global(ul),
  .article-body :global(ol) {
    padding-left: 24px;
    margin-bottom: 24px;
  }
  .article-body :global(li) {
    margin-bottom: 10px;
    font-size: 17px;
    line-height: 1.7;
    color: var(--text-medium);
  }
  .article-body :global(a) {
    color: var(--peach-gold);
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  .article-body :global(a:hover) {
    color: var(--dusty-mauve);
  }
  .article-body :global(strong) {
    color: var(--text-dark);
  }
  .article-body :global(blockquote) {
    border-left: 4px solid var(--peach-gold);
    padding: 20px 0 20px 28px;
    margin: 32px 0;
    font-family: var(--font-heading);
    font-style: italic;
    font-size: 22px;
    line-height: 1.5;
    color: var(--text-dark);
  }

  /* FAQ */
  .faq-heading {
    font-size: 30px;
    margin-bottom: 24px;
  }

  /* Author Box */
  .author-box {
    background: var(--warm-cream);
    border-left: 4px solid var(--peach-gold);
    border-radius: 0 16px 16px 0;
    padding: 36px 40px;
    display: flex;
    gap: 28px;
    align-items: flex-start;
  }
  .author-photo {
    width: 100px;
    height: 100px;
    border-radius: 50%;
    object-fit: cover;
    flex-shrink: 0;
    border: 3px solid var(--soft-rose);
  }
  .author-title-text {
    font-size: 14px;
    font-weight: 600;
    color: var(--peach-gold);
    text-transform: uppercase;
    letter-spacing: 1px;
    margin-bottom: 12px;
  }
  .author-label {
    font-size: 13px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    color: var(--text-light);
    margin-bottom: 4px;
  }
  .author-name {
    font-size: 26px;
    margin-bottom: 12px;
  }
  .author-bio {
    font-size: 15px;
    line-height: 1.7;
    margin-bottom: 16px;
  }
  .author-link {
    font-weight: 700;
    font-size: 15px;
    color: var(--peach-gold);
  }

  /* Blog CTA */
  .blog-cta {
    background: var(--dusty-mauve);
    padding: 80px 40px;
    text-align: center;
  }
  .blog-cta h2 {
    color: var(--text-dark);
    margin-bottom: 16px;
  }
  .blog-cta p {
    color: var(--text-dark);
    opacity: 0.8;
    max-width: 600px;
    margin: 0 auto 32px;
    font-size: 18px;
  }
  .blog-cta .section-label {
    color: var(--text-dark);
    opacity: 0.6;
  }
  .blog-cta .btn-secondary {
    color: var(--text-dark);
    border-color: var(--text-dark);
    opacity: 0.8;
  }
  .blog-cta .btn-secondary:hover {
    background: var(--text-dark);
    color: var(--white);
    opacity: 1;
  }

  @media (max-width: 768px) {
    .blog-hero h1 { font-size: 32px; }
    .blog-subtitle { font-size: 17px; }
    .glance-box { padding: 24px; }
    .author-box { padding: 28px 24px; }
    .blog-cta { padding: 56px 20px; }
    .article-body :global(h2) { font-size: 26px; }
    .article-body :global(p) { font-size: 17px; }
  }
</style>
