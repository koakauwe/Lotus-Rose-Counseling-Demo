---
import SchemaOrg from '../components/SchemaOrg.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface FAQItem {
  question: string;
  answer: string;
}

interface Props {
  title: string;
  description: string;
  faqSchema?: FAQItem[];
  preloadImage?: string;
  noHero?: boolean;
}

const { title, description, faqSchema, preloadImage, noHero } = Astro.props;
const canonicalURL = Astro.url.href;
const siteName = 'Lotus Rose Counseling';

// Build breadcrumb from URL path
const pathSegments = Astro.url.pathname.split('/').filter(Boolean);
const breadcrumbItems = [
  { name: 'Home', url: `${Astro.site}` }
];

pathSegments.forEach((segment, index) => {
  const url = `${Astro.site}${pathSegments.slice(0, index + 1).join('/')}/`;
  const name = segment
    .split('-')
    .map(word => word.charAt(0).toUpperCase() + word.slice(1))
    .join(' ');
  breadcrumbItems.push({ name, url });
});

const breadcrumbSchema = pathSegments.length > 0 ? {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": breadcrumbItems.map((item, index) => ({
    "@type": "ListItem",
    "position": index + 1,
    ...(index < breadcrumbItems.length - 1
      ? { "item": { "@id": item.url, "name": item.name } }
      : { "name": item.name }
    )
  }))
} : null;

const faqJsonLd = faqSchema && faqSchema.length > 0 ? {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqSchema.map(faq => ({
    "@type": "Question",
    "name": faq.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": faq.answer
    }
  }))
} : null;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="theme-color" content="#D4A574" />

  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalURL} />

  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:site_name" content={siteName} />
  <meta property="og:locale" content="en_US" />
  <meta property="og:image" content={`${Astro.site}og-image.jpg`} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={`${Astro.site}og-image.jpg`} />

  <!-- Favicons -->
  <link rel="icon" href="/favicon.ico" sizes="32x32" />
  <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
  <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
  <link rel="manifest" href="/site.webmanifest" />

  <!-- Preload Critical Fonts -->
  <link rel="preload" href="/fonts/cormorant-garamond-700-latin.woff2" as="font" type="font/woff2" crossorigin />
  <link rel="preload" href="/fonts/nunito-sans-latin.woff2" as="font" type="font/woff2" crossorigin />

  {preloadImage && <link rel="preload" href={preloadImage} as="image" />}

  <!-- Styles -->
  <style is:global>
    @import '../styles/fonts.css';
    @import '../styles/global.css';
  </style>

  <!-- Schema -->
  <SchemaOrg />
  {breadcrumbSchema && (
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  )}
  {faqJsonLd && (
    <script type="application/ld+json" set:html={JSON.stringify(faqJsonLd)} />
  )}

  <!-- Microsoft Clarity (deferred via requestIdleCallback for performance) -->
  <script>
    (function() {
      function loadClarity() {
        (function(c,l,a,r,i,t,y){
          c[a]=c[a]||function(){(c[a].q=c[a].q||[]).push(arguments)};
          t=l.createElement(r);t.async=1;t.src="https://www.clarity.ms/tag/"+i;
          y=l.getElementsByTagName(r)[0];y.parentNode.insertBefore(t,y);
        })(window, document, "clarity", "script", "w70hiukvqm");
      }
      if ('requestIdleCallback' in window) {
        requestIdleCallback(loadClarity, { timeout: 3000 });
      } else {
        setTimeout(loadClarity, 2000);
      }
    })();
  </script>
</head>
<body>
  <a href="#main-content" class="skip-to-content">Skip to main content</a>
  <Header />
  <main id="main-content">
    <slot />
  </main>
  <Footer />
</body>
</html>
