---
import BaseLayout from './BaseLayout.astro';
import MidPageCTA from '../components/MidPageCTA.astro';

interface FAQItem {
  question: string;
  answer: string;
}

interface Props {
  title: string;
  description: string;
  sectionLabel: string;
  heroTitle: string;
  heroSubtitle: string;
  heroImage?: string;
  ctaLabel?: string;
  ctaTitle?: string;
  ctaText?: string;
  faqSchema?: FAQItem[];
  therapySchema?: {
    name: string;
    description: string;
    alternateName?: string[];
  };
}

const {
  title,
  description,
  sectionLabel,
  heroTitle,
  heroSubtitle,
  heroImage = "/photos/office-1.jpg",
  ctaLabel = "Take the First Step",
  ctaTitle = "Ready to Start Healing?",
  ctaText = "Your first step is a free 15-minute consultation. No pressure — just a conversation about what you're going through and how we might help.",
  faqSchema,
  therapySchema
} = Astro.props;
---

<BaseLayout title={title} description={description} faqSchema={faqSchema}>

  <!-- Full-Bleed Service Hero -->
  <section class="hero-fullbleed">
    <div class="hero-fullbleed-bg">
      <img src={heroImage} alt={heroTitle} width="1920" height="1080" fetchpriority="high" />
    </div>
    <div class="hero-fullbleed-overlay"></div>
    <div class="hero-fullbleed-content">
      <p class="section-label">{sectionLabel}</p>
      <h1>{heroTitle}</h1>
      <p class="hero-subtitle">{heroSubtitle}</p>
      <div class="btn-group" style="justify-content: center;">
        <a href="/contact/" class="btn-primary">Schedule Free Consultation</a>
        <a href="/our-therapists/" class="btn-secondary">Meet Our Therapists</a>
      </div>
      <p class="hero-phone">
        <a href="tel:+18016424244">Or call (801) 642-4244</a>
      </p>
    </div>
  </section>

  <!-- Page Content -->
  <slot />

  <!-- CTA Section -->
  <section class="cta-section">
    <div class="container">
      <p class="section-label">{ctaLabel}</p>
      <h2>{ctaTitle}</h2>
      <p>{ctaText}</p>
      <div class="btn-group" style="justify-content: center;">
        <a href="/contact/" class="btn-primary">Schedule Free Consultation</a>
        <a href="tel:+18016424244" class="btn-secondary">Call (801) 642-4244</a>
      </div>
      <p class="service-area-text">Serving Orem, Provo, Lehi, American Fork, Pleasant Grove, Lindon &amp; surrounding Utah County. In-person and telehealth sessions available.</p>
    </div>
  </section>

  {therapySchema && (
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "MedicalTherapy",
      "@id": `https://lotusrosecounseling.com/#${therapySchema.name.toLowerCase().replace(/\s+/g, '-')}`,
      "name": therapySchema.name,
      "description": therapySchema.description,
      ...(therapySchema.alternateName && { "alternateName": therapySchema.alternateName }),
      "availableService": {
        "@type": "MedicalTherapy",
        "name": therapySchema.name,
        "provider": {
          "@id": "https://lotusrosecounseling.com/#business"
        }
      }
    }, null, 2)} />
  )}

</BaseLayout>

<style>
  .hero-phone {
    font-size: 15px;
    margin-top: 12px;
  }
  .hero-phone a {
    color: rgba(255,255,255,0.7);
    font-weight: 600;
  }
  .hero-phone a:hover { color: var(--peach-gold); }

  .service-area-text {
    margin-top: 28px;
    font-size: 14px;
    color: var(--text-medium);
    opacity: 0.7;
  }
</style>
